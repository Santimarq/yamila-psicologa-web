---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto y Turnos | Lic. Yamila Tabarez" description="Agenda tu evaluación, supervisión o solicita información sobre capacitaciones en salud mental infantil.">
    <!-- Header Hero -->
    <header class="relative py-24 lg:py-32 overflow-hidden flex items-center justify-center min-h-[45vh] bg-primary">
        <!-- Elegant Curved Overlay to match reference -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[150%] md:w-[120%] h-full bg-gradient-to-b from-white/15 to-transparent rounded-b-[100%] pointer-events-none"></div>
        
        <div class="container-custom relative z-10 text-center animate-fade-in-up">
            <span class="inline-block py-1 px-4 rounded-full bg-white/10 border border-white/20 text-white text-xs font-bold tracking-wider uppercase mb-6 backdrop-blur-sm shadow-sm">
                Contacto Directo
            </span>
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-heading font-extrabold text-white mb-6 tracking-tight drop-shadow-sm text-balance">Hablemos</h1>
            <p class="text-base sm:text-lg text-blue-50 max-w-xl mx-auto font-medium leading-relaxed drop-shadow-sm px-4">Agenda tu evaluación clínica, solicita acompañamiento familiar o resuelve cualquier inquietud profesional.</p>
        </div>
    </header>

    <div class="bg-bg-light pb-24 border-b border-secondary">
        <div class="container-custom relative z-20 -mt-16">
            
            <!-- Contact Methods Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16" data-reveal>
                <!-- WhatsApp -->
                <a href="https://wa.me/5492323331301" target="_blank" class="bg-white p-8 rounded-[2rem] shadow-lg border border-secondary hover:border-primary hover:shadow-xl transition-all group flex flex-col items-center text-center hover:-translate-y-1">
                    <div class="w-16 h-16 bg-blue-50 text-primary rounded-full flex items-center justify-center mb-6 group-hover:bg-blue-100 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                    </div>
                    <h3 class="font-heading font-bold text-xl text-text-dark mb-2">WhatsApp</h3>
                    <p class="text-text-body text-sm mb-4">Para consultas rápidas, turnos y urgencias.</p>
                    <span class="text-primary font-bold text-sm">+54 9 2323 33-1301</span>
                </a>

                <!-- Email -->
                <a href="mailto:licyamilatabarez@gmail.com" class="bg-white p-8 rounded-[2rem] shadow-lg border border-secondary hover:border-primary hover:shadow-xl transition-all group flex flex-col items-center text-center hover:-translate-y-1">
                    <div class="w-16 h-16 bg-blue-50 text-primary rounded-full flex items-center justify-center mb-6 group-hover:bg-blue-100 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    </div>
                    <h3 class="font-heading font-bold text-xl text-text-dark mb-2">Email</h3>
                    <p class="text-text-body text-sm mb-4">Para supervisiones o propuestas laborales.</p>
                    <span class="text-primary font-bold text-sm">licyamilatabarez@gmail.com</span>
                </a>

                <!-- Consultorio -->
                <div class="bg-white p-8 rounded-[2rem] shadow-lg border border-secondary hover:border-primary hover:shadow-xl transition-all flex flex-col items-center text-center hover:-translate-y-1">
                    <div class="w-16 h-16 bg-blue-50 text-primary rounded-full flex items-center justify-center mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h3 class="font-heading font-bold text-xl text-text-dark mb-2">Consultorio</h3>
                    <p class="text-text-body text-sm mb-2">Atención Presencial y Online.</p>
                    <span class="text-primary font-bold text-sm">Luján, Buenos Aires</span>
                </div>
            </div>

            <!-- Form Section -->
            <div class="max-w-4xl mx-auto bg-white p-8 md:p-14 lg:p-16 rounded-[3rem] shadow-[0_20px_60px_-15px_rgba(35,108,229,0.08)] border border-gray-100 relative overflow-hidden" data-reveal style="transition-delay:0.15s">
                <!-- Decorative element -->
                <div class="absolute top-0 right-0 w-80 h-80 bg-primary/5 rounded-full blur-3xl -mr-40 -mt-40 pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-80 h-80 bg-primary-dark/5 rounded-full blur-3xl -ml-40 -mb-40 pointer-events-none"></div>

                <div class="text-center mb-12 relative z-10">
                    <h2 class="text-3xl sm:text-4xl font-heading font-extrabold text-text-dark mb-4 text-balance">Envíanos un mensaje</h2>
                    <p class="text-text-body font-light text-base sm:text-lg max-w-xl mx-auto">Completa el formulario indicando tu necesidad y me comunicaré contigo a la brevedad para coordinar los próximos pasos.</p>
                </div>

                <form class="space-y-8 relative z-10" name="contacto" method="POST" data-netlify="true" netlify-honeypot="bot-field" id="contact-form">
                    <input type="hidden" name="form-name" value="contacto" />
                    <p class="hidden">
                        <label>No completes esto si eres humano: <input name="bot-field" /></label>
                    </p>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label for="nombre" class="text-sm font-bold text-text-dark ml-1">Nombre completo *</label>
                            <input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none bg-bg-light/80 hover:bg-white text-text-dark shadow-sm">
                        </div>
                        <div class="space-y-2">
                            <label for="email" class="text-sm font-bold text-text-dark ml-1">Email *</label>
                            <input type="email" id="email" name="email" required placeholder="tuemail@ejemplo.com" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none bg-bg-light/80 hover:bg-white text-text-dark shadow-sm">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="motivo" class="text-sm font-bold text-text-dark ml-1">Motivo de consulta *</label>
                        <select id="motivo" name="motivo" required class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none bg-bg-light/80 hover:bg-white text-text-dark shadow-sm appearance-none font-medium text-base">
                            <option value="">Selecciona una opción...</option>
                            <option value="evaluacion">Evaluación Infantil</option>
                            <option value="supervision">Supervisión Clínica</option>
                            <option value="acompanamiento">Acompañamiento Familiar</option>
                            <option value="otro">Otro motivo / Duda en general</option>
                        </select>
                    </div>

                    <div id="file-upload-container" class="space-y-3 hidden p-6 bg-blue-50/50 rounded-2xl border border-blue-100">
                        <label for="orden" class="text-sm font-bold text-text-dark flex items-center gap-3">
                            Adjuntar orden médica * 
                            <span class="text-[10px] bg-primary text-white tracking-wider px-2 py-1 rounded-md font-bold uppercase transition-all">Requerido</span>
                        </label>
                        <div class="relative">
                            <input type="file" id="orden" name="orden" accept=".pdf,.png,.jpg,.jpeg" class="block w-full text-sm text-text-body file:mr-5 file:py-3 file:px-6 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-white file:text-primary file:shadow-sm hover:file:bg-primary hover:file:text-white border border-gray-200 rounded-xl cursor-pointer bg-white file:cursor-pointer transition-all outline-none shadow-sm">
                        </div>
                        <p class="text-xs text-text-body/80 ml-1 font-medium">Formatos admitidos: JPG, PNG, PDF (Máx: 5MB)</p>
                    </div>

                    <div class="space-y-2">
                        <label for="mensaje" class="text-sm font-bold text-text-dark ml-1">Mensaje *</label>
                        <textarea id="mensaje" name="mensaje" rows="5" required placeholder="¿En qué te puedo ayudar o asesorar?" class="w-full px-5 py-4 rounded-xl border border-gray-200 focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none bg-bg-light/80 hover:bg-white text-text-dark shadow-sm resize-y"></textarea>
                    </div>

                    <div class="flex justify-center md:justify-start pt-2">
                        <button type="submit" class="inline-flex justify-center items-center bg-primary text-white hover:bg-primary-dark transition-all px-10 py-4 rounded-full text-[13px] tracking-widest uppercase font-bold shadow-md hover:-translate-y-0.5 w-full md:w-auto text-center gap-3 group">
                            Enviar Consulta
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </button>
                    </div>
                    
                    <p class="text-sm text-center text-text-body font-medium flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Tus datos están protegidos y son estrictamente confidenciales.
                    </p>
                </form>

                <!-- Success Message -->
                <div id="success-message" class="hidden bg-green-50/80 border border-green-200 text-green-800 p-10 rounded-3xl text-center relative z-10 mt-6 shadow-sm">
                    <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
                        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-green-600"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                    </div>
                    <h3 class="font-heading font-extrabold text-3xl mb-3 text-green-900">¡Gracias por tu mensaje!</h3>
                    <p class="text-lg mb-8 font-medium">Tu consulta ha sido enviada con éxito. Revisaré tu caso y me pondré en contacto muy pronto.</p>
                    <div class="bg-white p-6 rounded-2xl border border-green-100 inline-block text-left shadow-sm">
                        <p class="text-sm font-bold text-text-dark mb-2">Para consultas urgentes:</p>
                        <a href="https://wa.me/5492323331301" class="flex items-center gap-3 text-primary hover:text-primary-dark font-bold text-lg transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                            WhatsApp (+54) 9 2323 33-1301
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</Layout>

<script>
    // Logic to show file upload if "Evaluación Infantil" is selected
    const motivoSelect = document.getElementById('motivo') as HTMLSelectElement;
    const fileContainer = document.getElementById('file-upload-container');
    const fileInput = document.getElementById('orden') as HTMLInputElement;
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const successMsg = document.getElementById('success-message');

    // Handle Check URL Params for pre-selection
    const urlParams = new URLSearchParams(window.location.search);
    const motivoParam = urlParams.get('motivo');
    
    if(motivoParam && motivoSelect) {
        motivoSelect.value = motivoParam;
        if(fileContainer && fileInput && motivoParam === 'evaluacion') {
            fileContainer.classList.remove('hidden');
            fileInput.required = true;
        }
    }

    motivoSelect?.addEventListener('change', (e) => {
        const target = e.target as HTMLSelectElement;
        if (target.value === 'evaluacion') {
            fileContainer?.classList.remove('hidden');
            if(fileInput) fileInput.required = true;
        } else {
            fileContainer?.classList.add('hidden');
            if(fileInput) fileInput.required = false;
        }
    });

    // Handle Form Submit to Netlify
    form?.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'Enviando...';
        submitBtn.disabled = true;

        const formData = new FormData(form);

        fetch("/", {
            method: "POST",
            body: formData,
        })
        .then(() => {
            // Smooth transition
            form.classList.add('opacity-0');
            setTimeout(() => {
                form.classList.add('hidden');
                successMsg?.classList.remove('hidden');
                successMsg?.classList.add('animate-fade-in-up');
            }, 300);
        })
        .catch((error) => {
            console.error('Error submitting form', error);
            alert('Hubo un error al enviar el mensaje. Por favor intenta mediante WhatsApp.');
            submitBtn.innerHTML = originalBtnText;
            submitBtn.disabled = false;
        });
    });
</script>
