---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import evalImg from '../assets/servicio_evaluaciones.jpg';
import supImg from '../assets/servicio_supervision.png';
import acompImg from '../assets/servicio_acompanamiento.png';
---

<Layout title="Inicio" description="Psicóloga infantil en Luján y online. Especialista en Autismo, TEA y neurodesarrollo. Evaluaciones ADOS/ADI-R, terapia ABA y acompañamiento familiar en Argentina. Lic. Yamila Tabarez.">

    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 1: HERO                            -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="relative hero-gradient overflow-hidden">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-24 lg:pt-32 lg:pb-40">
            <div class="grid lg:grid-cols-2 gap-12 items-center">

                <!-- Hero Content -->
                <div class="relative z-10 animate-fade-in-up" data-reveal>
                    <span class="inline-block py-1.5 px-4 rounded-full bg-blue-50 text-primary text-xs font-bold uppercase tracking-wider mb-6 border border-blue-100">
                        Atención presencial y online
                    </span>

                    <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl text-text-dark mb-6 leading-[1.15] text-balance font-extrabold">
                        Psicología · Desarrollo Infantil · <br class="hidden lg:block"/><span class="text-primary">Neurodiversidad</span>
                    </h1>

                    <p class="text-lg text-primary font-medium mb-4 italic">
                        Abordaje clínico en TEA y neurodesarrollo
                    </p>

                    <p class="text-text-body text-lg mb-10 max-w-xl leading-relaxed">
                        Soy Yamila Tabarez, Licenciada en psicología. Brindo evaluaciones clínicas, orientación a familias y herramientas con evidencia científica para potenciar el desarrollo infantil y el bienestar familiar.
                    </p>

                    <div class="flex flex-wrap gap-4">
                        <a href="/sobre-mi" class="sm:w-auto text-center px-8 py-4 bg-primary text-white rounded-xl font-semibold hover:bg-primary-dark transition-all shadow-lg shadow-blue-200 hover:-translate-y-0.5">
                            Conocé más sobre mí
                        </a>
                        <a href="/servicios" class="sm:w-auto text-center px-8 py-4 bg-white text-primary border border-primary/20 rounded-xl font-semibold hover:bg-secondary transition-all hover:-translate-y-0.5">
                            Ver servicios
                        </a>
                    </div>


                </div>

                <!-- Hero Image -->
                <div class="relative flex justify-center lg:justify-end" data-reveal="right" style="transition-delay:0.15s">
                    <div class="relative w-full max-w-md lg:max-w-lg">
                        <!-- Decorative blurred elements -->
                        <div class="absolute -top-10 -right-10 w-64 h-64 bg-blue-100 rounded-full blur-3xl opacity-60 -z-10"></div>
                        <div class="absolute -bottom-10 -left-10 w-48 h-48 bg-primary/10 rounded-full blur-2xl opacity-50 -z-10"></div>

                        <!-- Main Photo Container -->
                        <div class="relative rounded-3xl overflow-hidden shadow-2xl border-8 border-white">
                        <img
                            src="/hero-image-hq.png"
                            alt="Lic. Yamila Tabarez - Psicóloga Infantil en Argentina especializada en autismo"
                            class="w-full h-auto object-cover aspect-[4/5]"
                        />
                        </div>

                        <!-- Floating badges -->
                        <div class="absolute -bottom-4 -left-4 bg-white rounded-2xl shadow-xl px-5 py-3 floating-badge hidden md:flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3.332.883-4.5 2.157C10.832 3.883 9.26 3 7.5 3A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                            </div>
                            <div>
                                <p class="text-sm font-bold text-text-dark leading-tight">Psicología</p>
                                <p class="text-xs text-text-body">Desarrollo Infantil · Neurodiversidad</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 2: SERVICIOS ESPECIALIZADOS        -->
    <!-- ═══════════════════════════════════════════ -->
    <section id="servicios" class="py-32 bg-white relative overflow-hidden">
        <!-- Decorative bg blur -->
        <div class="absolute top-0 right-0 w-1/3 h-1/2 bg-primary/5 rounded-full blur-[100px] pointer-events-none"></div>
        
        <div class="container-custom relative z-10">
            <div class="text-center max-w-3xl mx-auto mb-10 flex flex-col items-center" data-reveal>
                <div class="flex items-center gap-4 mb-4">
                    <div class="w-8 h-px bg-primary/40"></div>
                    <span class="text-xs font-bold tracking-[0.2em] text-primary uppercase">Mis servicios</span>
                    <div class="w-8 h-px bg-primary/40"></div>
                </div>
                <h2 class="text-3xl md:text-[40px] font-heading font-bold text-text-dark leading-tight">Evaluaciones diagnósticas y del desarrollo infanto juvenil</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                <!-- Service 1: Evaluaciones Infantiles -->
                <a href="/servicios" class="group block bg-white rounded-[2rem] p-3 shadow-[0_15px_40px_-10px_rgba(35,108,229,0.15)] border border-gray-50 hover:shadow-[0_25px_50px_-12px_rgba(35,108,229,0.3)] transition-all duration-500 hover:-translate-y-2" data-reveal style="transition-delay:0.1s">
                    <div class="relative h-64 rounded-3xl overflow-hidden mb-6">
                        <Image
                            src={evalImg}
                            alt="Evaluaciones Infantiles - Psicóloga Infantil"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                            widths={[400, 600]}
                            sizes="(max-width: 768px) 100vw, 33vw"
                            quality={100}
                            format="webp"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="px-5 pb-6">
                        <h3 class="text-2xl font-heading font-bold text-text-dark mb-3 group-hover:text-primary transition-colors">Evaluaciones Infantiles</h3>
                        <p class="text-text-body font-light leading-relaxed">Diagnósticos precisos basados en evidencia clínica para entender el perfil único de cada niño y su desarrollo.</p>
                    </div>
                </a>

                <!-- Service 2: Supervisión Clínica -->
                <a href="/servicios" class="group block bg-white rounded-[2rem] p-3 shadow-[0_15px_40px_-10px_rgba(35,108,229,0.15)] border border-gray-50 hover:shadow-[0_25px_50px_-12px_rgba(35,108,229,0.3)] transition-all duration-500 hover:-translate-y-2" data-reveal style="transition-delay:0.22s">
                    <div class="relative h-64 rounded-3xl overflow-hidden mb-6">
                        <Image
                            src={supImg}
                            alt="Supervisión Clínica - Psicóloga Infantil"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                            widths={[400, 600]}
                            sizes="(max-width: 768px) 100vw, 33vw"
                            quality={100}
                            format="webp"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="px-5 pb-6">
                        <h3 class="text-2xl font-heading font-bold text-text-dark mb-3 group-hover:text-primary transition-colors">Supervisión Clínica</h3>
                        <p class="text-text-body font-light leading-relaxed">Acompañamiento profesional a colegas en formación con herramientas de supervisión actualizadas.</p>
                    </div>
                </a>

                <!-- Service 3: Acompañamiento Familiar -->
                <a href="/servicios" class="group block bg-white rounded-[2rem] p-3 shadow-[0_15px_40px_-10px_rgba(35,108,229,0.15)] border border-gray-50 hover:shadow-[0_25px_50px_-12px_rgba(35,108,229,0.3)] transition-all duration-500 hover:-translate-y-2" data-reveal style="transition-delay:0.34s">
                    <div class="relative h-64 rounded-3xl overflow-hidden mb-6">
                        <Image
                            src={acompImg}
                            alt="Acompañamiento Familiar - Psicóloga Infantil"
                            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                            widths={[400, 600]}
                            sizes="(max-width: 768px) 100vw, 33vw"
                            quality={100}
                            format="webp"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <div class="px-5 pb-6">
                        <h3 class="text-2xl font-heading font-bold text-text-dark mb-3 group-hover:text-primary transition-colors">Acompañamiento Familiar</h3>
                        <p class="text-text-body font-light leading-relaxed">Orientación cercana para madres y padres, brindando estrategias y respuestas para el día a día.</p>
                    </div>
                </a>
            </div>

            <div class="text-center mt-16">
                <a href="/servicios" class="group inline-flex items-center gap-3 bg-primary text-white px-6 py-3 rounded-full font-bold text-sm tracking-wide hover:bg-primary-dark transition-all duration-300 shadow-[0_10px_20px_-10px_rgba(35,108,229,0.5)] hover:-translate-y-1">
                    Explorar todos los servicios
                    <span class="bg-white/20 p-1.5 rounded-full group-hover:bg-white group-hover:text-primary transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </span>
                </a>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 3: SOBRE MÍ / ENFOQUE              -->
    <!-- ═══════════════════════════════════════════ -->
    <section id="sobre-mi" class="py-32 bg-secondary/30 border-y border-gray-100 overflow-hidden relative">
        <div class="container-custom relative z-10">
            <div class="flex flex-col lg:flex-row gap-16 lg:gap-24 items-center">
                <!-- Image Container (Left) -->
                <div class="w-full lg:w-5/12 relative" data-reveal="left">
                    <div class="relative rounded-[2rem] overflow-hidden shadow-2xl z-10 border-4 border-white/50">
                        <img
                            src="/yamila-about.jpg"
                            alt="Lic. Yamila Tabarez - Psicóloga Infantil"
                            class="w-full h-auto object-cover"
                        />
                    </div>
                    <!-- Decorative background elements -->
                    <div class="absolute -top-12 -left-12 w-64 h-64 bg-primary/10 rounded-full blur-3xl -z-10"></div>
                    <div class="absolute -bottom-6 -right-6 w-full h-full border-2 border-primary/20 rounded-[2rem] -z-10 translate-x-4 translate-y-4"></div>
                </div>

                <!-- Text Container (Right) -->
                <div class="w-full lg:w-7/12" data-reveal="right" style="transition-delay:0.15s">
                    <div class="flex items-center gap-4 mb-6">
                        <div class="w-10 h-px bg-primary"></div>
                        <span class="text-xs font-bold tracking-[0.2em] text-primary uppercase">Sobre Mí</span>
                    </div>
                    
                    <h2 class="text-3xl md:text-[40px] font-heading font-bold text-text-dark mb-8 leading-tight">
                        Un enfoque humano para el <span class="text-primary">neurodesarrollo</span>
                    </h2>

                    <div class="space-y-6 text-text-body font-light leading-relaxed mb-12">
                        <p class="text-xl text-text-dark font-medium leading-snug">
                            Soy psicóloga egresada de la Universidad de Buenos Aires (UBA) y Coach Ontológico certificada por la Federación Internacional de Coaching (ICF).
                        </p>
                        <p class="text-lg">
                            Mi motivación diaria y especialidad es el <strong>neurodesarrollo infantil</strong>. Estoy diplomada en Análisis Conductual Aplicado (ABA) y creo que cada niño es un mundo llenísimo de posibilidades, buscando siempre el puente para conectar su potencial con su entorno.
                        </p>
                    </div>

                    <!-- Action Button -->
                    <div>
                        <a href="/sobre-mi" class="group inline-flex items-center gap-3 bg-primary text-white px-6 py-3 rounded-full font-bold text-sm tracking-wide hover:bg-primary-dark transition-all duration-300 shadow-[0_10px_20px_-10px_rgba(35,108,229,0.5)] hover:-translate-y-1">
                            Conocé más sobre mí
                            <span class="bg-white/20 p-1.5 rounded-full group-hover:bg-white group-hover:text-primary transition-colors">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 4: ¿POR QUÉ TRABAJAR CONMIGO?     -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="py-24 bg-white relative overflow-hidden">
        <!-- Subtle Background Elements -->
        <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-primary/5 to-transparent pointer-events-none"></div>
        
        <div class="container-custom relative z-10">
            <div class="text-center max-w-3xl mx-auto flex flex-col items-center" data-reveal>
                <h2 class="text-3xl md:text-[40px] font-heading font-bold text-text-dark leading-tight">
                    ¿Por qué trabajar <span class="text-primary">conmigo</span>?
                </h2>
                <p class="mt-6 text-lg text-text-body font-light leading-relaxed max-w-2xl">
                    Más que un tratamiento, ofrezco un espacio seguro de contención y herramientas concretas para acompañar el desarrollo de tu hijo en sus contextos naturales y promover el bienestar familiar.
                </p>
            </div>
        </div>
    </section>


    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 5: CTA FINAL                       -->
    <!-- ═══════════════════════════════════════════ -->
    <section class="py-24 bg-[#FBFAF9] relative overflow-hidden border-t border-gray-100">
        <!-- Subtle decorative shapes -->
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_top_right,rgba(35,108,229,0.03),transparent_50%)] pointer-events-none"></div>

        <div class="container-custom relative z-10 px-4 md:px-8">
            <div class="bg-white rounded-[3rem] shadow-[0_20px_60px_-15px_rgba(35,108,229,0.1)] border border-gray-50 max-w-[1400px] mx-auto overflow-hidden relative" data-reveal>
                <!-- Inner decoration -->
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
                
                <div class="grid lg:grid-cols-12 items-stretch">
                    
                    <!-- Text Content -->
                    <div class="lg:col-span-5 p-8 md:p-16 lg:p-20 flex flex-col justify-center order-2 lg:order-1 text-center lg:text-left">
                        <div class="flex items-center justify-center lg:justify-start gap-4 mb-6">
                            <div class="w-8 h-px bg-primary/40 hidden lg:block"></div>
                            <span class="text-xs font-bold tracking-[0.2em] text-primary uppercase">Demos el primer paso</span>
                            <div class="w-8 h-px bg-primary/40"></div>
                        </div>
                        
                        <h2 class="text-3xl sm:text-4xl md:text-[42px] font-heading font-extrabold text-text-dark mb-6 leading-tight">
                            Comencemos este <span class="text-primary">camino</span> juntos
                        </h2>
                        
                        <p class="text-text-body font-light text-lg mb-10 leading-relaxed max-w-lg mx-auto lg:mx-0">
                            Si buscás una evaluación profesional, espacio de supervisión o necesitás orientación para el desarrollo de tu hijo/a, estoy aquí para escucharte y acompañarte en cada etapa del proceso.
                        </p>
                        
                        <a href="/contacto" class="inline-flex items-center justify-center gap-3 bg-primary text-white px-7 py-3 rounded-full font-medium hover:bg-primary-dark transition-all duration-300 shadow-md hover:shadow-lg hover:-translate-y-0.5 text-[15px]">
                            Agendar mi primer turno
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </a>
                    </div>

                    <!-- Image Content -->
                    <div class="lg:col-span-7 order-1 lg:order-2 relative min-h-[400px] lg:min-h-0">
                        <img
                            src="/yamila-cta.png"
                            alt="Yamila Tabarez trabajando en su computadora"
                            class="absolute inset-0 w-full h-full object-cover object-center"
                        />
                        <!-- Gradient Overlay to blend with white background -->
                        <div class="absolute inset-0 bg-gradient-to-b lg:bg-gradient-to-r from-white/20 via-transparent to-transparent hidden lg:block"></div>
                    </div>

                </div>
            </div>
        </div>
    </section>

</Layout>
