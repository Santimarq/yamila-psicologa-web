---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Psicóloga infantil en Argentina especializada en Autismo, TEA y neurodesarrollo. Evaluaciones ADOS/ADI-R, terapia ABA y acompañamiento familiar. Atención en Luján y online." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es-AR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />

		<!-- SEO Primary -->
		<title>{title} | Lic. Yamila Tabarez - Psicóloga Infantil Argentina</title>
		<meta name="description" content={description} />
		<meta name="keywords" content="psicóloga infantil, autismo, TEA, evaluación ADOS, ADI-R, terapia ABA, neurodesarrollo, psicóloga niños, Argentina, Buenos Aires, Luján, desarrollo infantil, neurodiversidad, acompañamiento familiar" />
		<meta name="author" content="Lic. Yamila Tabarez" />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Geo Tags Argentina -->
		<meta name="geo.region" content="AR-B" />
		<meta name="geo.placename" content="Luján, Buenos Aires, Argentina" />
		<meta name="geo.position" content="-34.5703;-59.1050" />
		<meta name="ICBM" content="-34.5703, -59.1050" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={`${title} | Lic. Yamila Tabarez - Psicóloga Infantil`} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL('/yamila-about.jpg', Astro.url)} />
		<meta property="og:locale" content="es_AR" />
		<meta property="og:site_name" content="Lic. Yamila Tabarez - Psicóloga Infantil" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={Astro.url} />
		<meta name="twitter:title" content={`${title} | Lic. Yamila Tabarez - Psicóloga Infantil`} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={new URL('/yamila-about.jpg', Astro.url)} />

		<!-- Schema.org JSON-LD -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "LocalBusiness",
			"@id": "https://licyamilatabarez.com.ar",
			"name": "Lic. Yamila Tabarez - Psicóloga Infantil",
			"description": "Psicóloga especializada en autismo, TEA y neurodesarrollo infantil. Evaluaciones diagnósticas ADOS/ADI-R, terapia ABA y acompañamiento familiar en Argentina.",
			"url": "https://licyamilatabarez.com.ar",
			"telephone": "+54-2323-536138",
			"email": "licyamilatabarez@gmail.com",
			"image": "https://licyamilatabarez.com.ar/yamila-about.jpg",
			"priceRange": "$$",
			"address": {
				"@type": "PostalAddress",
				"addressLocality": "Luján",
				"addressRegion": "Buenos Aires",
				"addressCountry": "AR"
			},
			"geo": {
				"@type": "GeoCoordinates",
				"latitude": -34.5703,
				"longitude": -59.1050
			},
			"openingHoursSpecification": {
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
				"opens": "09:00",
				"closes": "17:00"
			},
			"sameAs": [],
			"areaServed": {
				"@type": "Country",
				"name": "Argentina"
			},
			"hasOfferCatalog": {
				"@type": "OfferCatalog",
				"name": "Servicios de Psicología Infantil",
				"itemListElement": [
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Evaluaciones Clínicas",
							"description": "Evaluaciones diagnósticas ADOS y ADI-R para detección de autismo y TEA"
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Supervisión Clínica",
							"description": "Supervisión para profesionales bajo el marco del Análisis Aplicado de la Conducta (ABA)"
						}
					},
					{
						"@type": "Offer",
						"itemOffered": {
							"@type": "Service",
							"name": "Acompañamiento Familiar",
							"description": "Orientación y herramientas para familias de niños con necesidades de apoyo"
						}
					}
				]
			}
		})} />

		<!-- Person Schema -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Yamila Tabarez",
			"jobTitle": "Licenciada en Psicología",
			"description": "Psicóloga infantil especializada en Autismo y Análisis Conductual Aplicado (ABA)",
			"url": "https://licyamilatabarez.com.ar",
			"image": "https://licyamilatabarez.com.ar/yamila-about.jpg",
			"sameAs": [],
			"worksFor": {
				"@type": "Organization",
				"name": "E.S.DI - Espacio para el Desarrollo Infantil"
			},
			"alumniOf": [
				{
					"@type": "CollegeOrUniversity",
					"name": "Universidad de Buenos Aires (UBA)"
				},
				{
					"@type": "CollegeOrUniversity",
					"name": "Universidad Abierta Interamericana (UAI)"
				}
			],
			"knowsAbout": ["Autismo", "TEA", "ABA", "Neurodesarrollo", "Psicología Infantil", "ADOS", "ADI-R"]
		})} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body class="flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow pt-20">
			<slot />
		</main>
		<Footer />

		<!-- Scroll Reveal -->
		<script>
			function initReveal() {
				const els = document.querySelectorAll('[data-reveal]');
				const observer = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						}
					});
				}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
				els.forEach(el => observer.observe(el));
			}
			initReveal();
			document.addEventListener('astro:page-load', initReveal);
		</script>

		<!-- Floating WhatsApp Button -->
		<a href="https://wa.me/542323536138?text=Hola%2C%20muchas%20gracias%20por%20tu%20mensaje.%20D%C3%A9jame%20tu%20consulta%20escrita%20y%20responder%C3%A9%20a%20la%20brevedad%20dentro%20de%20los%20d%C3%ADas%20y%20horarios%20de%20atenci%C3%B3n%3A%20Lunes%20a%20viernes%20de%209%20a%2017%20hs" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 md:bottom-10 md:right-10 z-50 bg-[#25D366] text-white p-4 rounded-full shadow-[0_8px_25px_-8px_rgba(37,211,102,0.6)] hover:bg-[#20BE5C] hover:shadow-[0_12px_30px_-10px_rgba(37,211,102,0.8)] transition-all duration-300 hover:-translate-y-1 group flex items-center justify-center animate-fade-in-up" aria-label="Contactar por WhatsApp">
			<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="group-hover:scale-110 transition-transform"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
			
			<!-- Tooltip -->
			<span class="absolute right-full mr-4 bg-white text-text-dark text-sm font-bold py-2 px-4 rounded-2xl shadow-xl opacity-0 group-hover:opacity-100 transition-all duration-300 whitespace-nowrap pointer-events-none translate-y-1 group-hover:translate-y-0 flex items-center gap-2">
				<span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
				¡Escribime!
				<!-- Triangulito del tooltip -->
				<span class="absolute top-1/2 -translate-y-1/2 -right-1 w-2 h-2 bg-white rotate-45"></span>
			</span>
		</a>
	</body>
</html>
